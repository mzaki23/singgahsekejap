# =============================================================================
# EXPLORE BATAM — Environment Variables untuk Production (Vercel)
# =============================================================================
# Salin variabel-variabel ini ke Vercel Dashboard → Settings → Environment Variables
# Jangan commit file .env yang berisi nilai asli ke GitHub!
# =============================================================================

# --- DATABASE (Neon / Vercel Postgres) ----------------------------------------
# Connection string utama PostgreSQL
POSTGRES_URL=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require

# URL dengan pgbouncer untuk connection pooling (dipakai Prisma / pg di runtime)
POSTGRES_PRISMA_URL=postgres://USER:PASSWORD@HOST/DATABASE?pgbouncer=true&connect_timeout=15

# URL tanpa pooling — dipakai untuk migrations / direct queries
POSTGRES_URL_NON_POOLING=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require

# --- NEXTAUTH ------------------------------------------------------------------
# URL produksi lengkap, contoh: https://explore-batam.vercel.app
NEXTAUTH_URL=https://YOUR_DOMAIN.vercel.app

# Secret acak 32 byte — generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_-base64_32

# --- CLOUDINARY ---------------------------------------------------------------
# Dari Cloudinary Dashboard → Settings → API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Nama upload preset yang sudah dibuat di Cloudinary (unsigned preset)
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# --- APP URL ------------------------------------------------------------------
# URL publik aplikasi (sama dengan NEXTAUTH_URL)
NEXT_PUBLIC_APP_URL=https://YOUR_DOMAIN.vercel.app

# URL base API (dipakai untuk fetch sisi client)
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN.vercel.app/api
